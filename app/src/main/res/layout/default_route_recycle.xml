<?xml version="1.0" encoding="UTF-8" ?>
<RelativeLayout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:ignore="MissingPrefix"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/default_route_header"
                android:textColor="#3F51B5"
                android:textStyle="bold"
                android:textSize="23sp"
                android:text="Route Info:"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/spl_id"
                android:layout_below="@+id/default_route_header"
                android:layout_marginTop="10dp"
                android:layout_marginStart="10dp"
                android:textSize="17sp"
                android:text="ROUTE ID: "
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/spl_recorded_on"
                android:layout_below="@+id/spl_id"
                android:layout_marginTop="10dp"
                android:layout_marginStart="10dp"
                android:textSize="17sp"
                android:text="ROUTE NAME: "
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/route_id"
                android:layout_below="@id/default_route_header"
                android:layout_marginTop="10dp"
                android:layout_marginStart="190dp"
                android:textSize="17sp"
                android:text="ID"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/route_name"
                android:layout_below="@id/route_id"
                android:layout_marginTop="10dp"
                android:layout_marginStart="150dp"
                android:textSize="17sp"
                android:text="ROUTE NAME"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </RelativeLayout>


    </androidx.cardview.widget.CardView>

</RelativeLayout>